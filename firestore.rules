rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── HELPERS ───────────────────────────────────────────────
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Group membership check
    function isMemberOfGroup(groupId) {
      return isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids);
    }

    // ─── ENTITY VALIDATORS ──────────────────────────────────────
    
    function isValidUser(data) {
      return (request.method == 'create' ? (data.keys().hasAll(['uid', 'name', 'email', 'createdAt', 'prefs']) && data.uid == request.auth.uid) : true)
        && (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() <= 100))
        && (!('email' in data) || (data.email is string && data.email.size() > 0 && data.email.size() <= 100))
        && (!('avatar' in data) || data.avatar is string);
    }

    function isValidFriend(data) {
      return (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() <= 100))
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 20))
        && (!('email' in data) || (data.email is string && data.email.size() <= 100));
    }

    function isValidGroup(data) {
      return (request.method == 'create' ? (data.keys().hasAll(['name', 'emoji', 'members', 'memberUids', 'leader', 'leaderUid', 'inviteCode', 'createdBy', 'createdAt']) && data.createdBy == request.auth.uid) : true)
        && (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() <= 100))
        && (!('emoji' in data) || data.emoji is string)
        && (!('members' in data) || data.members is list)
        && (!('memberUids' in data) || data.memberUids is list)
        && (!('leader' in data) || data.leader is string)
        && (!('leaderUid' in data) || data.leaderUid is string)
        && (!('inviteCode' in data) || data.inviteCode is string);
    }

    function isValidInvitation(data) {
      return (request.method == 'create' ? data.keys().hasAll(['groupId', 'inviterName', 'email', 'ts']) : true)
        && (!('groupId' in data) || data.groupId is string)
        && (!('inviterName' in data) || data.inviterName is string)
        && (!('email' in data) || data.email is string)
        && (!('ts' in data) || data.ts is number);
    }

    function isValidExpense(data) {
        return (request.method == 'create' ? (data.keys().hasAll(['desc', 'amount', 'payers', 'splitMode', 'splits', 'ts', 'createdBy']) && data.createdBy == request.auth.uid) : true)
            && (!('desc' in data) || (data.desc is string && data.desc.size() > 0 && data.desc.size() <= 200))
            && (!('amount' in data) || (data.amount is number && data.amount > 0))
            && (!('payers' in data) || data.payers is map)
            && (!('splits' in data) || data.splits is map)
            && (!('splitMode' in data) || (data.splitMode in ['equal', 'percent', 'adjust', 'itemized']))
            && (!('memberDetails' in data) || data.memberDetails is map);
    }

    function isValidPayment(data) {
        return (request.method == 'create' ? (data.keys().hasAll(['from', 'to', 'amount', 'ts', 'createdBy']) && data.createdBy == request.auth.uid) : true)
            && (!('from' in data) || data.from is string)
            && (!('to' in data) || data.to is string)
            && (!('amount' in data) || (data.amount is number && data.amount > 0));
    }

    function isValidFeedItem(data) {
        return data.keys().hasAll(['type', 'text', 'ts'])
            && data.type is string && data.text is string
            && data.ts is number;
    }

    // ─── MATCH BLOCKS ───────────────────────────────────────────

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isVerified() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isVerified() && request.auth.uid == userId && isValidUser(incoming())
                       && incoming().uid == existing().uid // Immutable UID
                       && (
                         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'prefs'])
                       );
      
      match /friends/{friendId} {
        allow list, get: if isSignedIn() && request.auth.uid == userId;
        allow create: if isVerified() && request.auth.uid == userId && isValidFriend(incoming());
        allow update: if isVerified() && request.auth.uid == userId && isValidFriend(incoming());
        allow delete: if isVerified() && request.auth.uid == userId;
      }
    }

    match /invitations/{inviteId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.email == request.auth.token.email);
      allow create: if isVerified() && isMemberOfGroup(incoming().groupId) && isValidInvitation(incoming());
      allow delete: if isVerified() && (isMemberOfGroup(existing().groupId) || request.auth.uid in get(/databases/$(database)/documents/groups/$(existing().groupId)).data.memberUids);
    }

    match /groups/{groupId} {
      allow list: if isSignedIn() && request.auth.uid in resource.data.memberUids;
      allow get: if isSignedIn();
      
      allow create: if isVerified() && isValidGroup(incoming()) && request.auth.uid in incoming().memberUids;
      
      allow update: if isVerified() && isValidGroup(incoming())
        && (
          // Action: Edit metadata (member only)
          (isMemberOfGroup(groupId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'emoji', 'dueDate'])) ||
          // Action: Manage members (member only)
          (isMemberOfGroup(groupId) && incoming().diff(existing()).affectedKeys().hasOnly(['members', 'memberUids', 'memberDetails'])) ||
          // Action: Join (non-member joining via invite)
          (!isMemberOfGroup(groupId) && request.auth.uid in incoming().memberUids && incoming().diff(existing()).affectedKeys().hasOnly(['members', 'memberUids', 'memberDetails'])) ||
          // Admin override
          (existing().leaderUid == request.auth.uid)
        );
      
      allow delete: if isVerified() && existing().leaderUid == request.auth.uid;

      match /expenses/{expenseId} {
        allow list, get: if isMemberOfGroup(groupId);
        allow create: if isVerified() && isMemberOfGroup(groupId) && isValidExpense(incoming());
        allow update: if isVerified() && isMemberOfGroup(groupId) && isValidExpense(incoming()) && incoming().createdBy == existing().createdBy;
        allow delete: if isVerified() && isMemberOfGroup(groupId) && (existing().createdBy == request.auth.uid || get(/databases/$(database)/documents/groups/$(groupId)).data.leaderUid == request.auth.uid);
      }

      match /payments/{paymentId} {
        allow list, get: if isMemberOfGroup(groupId);
        allow create: if isVerified() && isMemberOfGroup(groupId) && isValidPayment(incoming());
        allow update: if isVerified() && isMemberOfGroup(groupId) && isValidExpense(incoming()) && incoming().createdBy == existing().createdBy;
        allow delete: if isVerified() && isMemberOfGroup(groupId) && (existing().createdBy == request.auth.uid || get(/databases/$(database)/documents/groups/$(groupId)).data.leaderUid == request.auth.uid);
      }

      match /feed/{feedId} {
        allow list, get: if isMemberOfGroup(groupId);
        allow create: if isVerified() && isMemberOfGroup(groupId) && isValidFeedItem(incoming());
      }
    }
  }
}
