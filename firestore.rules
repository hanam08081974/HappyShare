rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── HELPERS ───────────────────────────────────────────────
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Group membership check
    function isMemberOfGroup(groupId) {
      let groupDoc = get(/databases/$(database)/documents/groups/$(groupId));
      return isSignedIn() && (
        (request.auth.uid in groupDoc.data.get('memberUids', [])) || 
        groupDoc.data.get('leaderUid', '') == request.auth.uid
      );
    }

    // ─── ENTITY VALIDATORS ──────────────────────────────────────
    
    function isValidUser(data) {
      return (request.method == 'create' ? (data.keys().hasAll(['uid', 'name', 'email', 'createdAt', 'prefs']) && data.uid == request.auth.uid) : true)
        && (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() <= 100))
        && (!('email' in data) || (data.email is string && data.email.size() > 0 && data.email.size() <= 100))
        && (!('avatar' in data) || data.avatar is string);
    }

    function isValidFriend(data) {
      return (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() <= 100))
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 20))
        && (!('email' in data) || (data.email is string && data.email.size() <= 100));
    }

    function isValidGroup(data) {
      return (request.method == 'create' ? (data.keys().hasAll(['name', 'emoji', 'members', 'memberUids', 'leader', 'leaderUid', 'inviteCode', 'createdBy', 'createdAt']) && data.createdBy == request.auth.uid) : true)
        && (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() <= 100))
        && (!('emoji' in data) || data.emoji is string)
        && (!('members' in data) || data.members is list)
        && (!('memberUids' in data) || data.memberUids is list)
        && (!('leader' in data) || data.leader is string)
        && (!('leaderUid' in data) || data.leaderUid is string)
        && (!('inviteCode' in data) || data.inviteCode is string)
        && (!('memberDetails' in data) || data.memberDetails is map);
    }

    function isValidExpense(data) {
        return (request.method == 'create' ? (data.keys().hasAll(['desc', 'amount', 'payers', 'splitMode', 'splits', 'ts', 'createdBy']) && data.createdBy == request.auth.uid) : true)
            && (!('desc' in data) || (data.desc is string && data.desc.size() > 0 && data.desc.size() <= 200))
            && (!('amount' in data) || (data.amount is number && data.amount > 0))
            && (!('payers' in data) || data.payers is map)
            && (!('splits' in data) || data.splits is map)
            && (!('splitMode' in data) || (data.splitMode in ['equal', 'percent', 'adjust', 'itemized']))
            && (!('memberDetails' in data) || data.memberDetails is map);
    }

    function isValidPayment(data) {
        return (request.method == 'create' ? (data.keys().hasAll(['from', 'to', 'amount', 'ts', 'createdBy']) && data.createdBy == request.auth.uid) : true)
            && (!('from' in data) || data.from is string)
            && (!('to' in data) || data.to is string)
            && (!('amount' in data) || (data.amount is number && data.amount > 0));
    }

    function isValidFeedItem(data) {
        return data.keys().hasAll(['type', 'text', 'ts'])
            && data.type is string && data.text is string
            && data.ts is number;
    }

    // ─── MATCH BLOCKS ───────────────────────────────────────────

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isVerified() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isVerified() && request.auth.uid == userId && isValidUser(incoming())
                       && incoming().uid == existing().uid // Immutable UID
                       && (
                         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'prefs', 'avatar'])
                       );
      allow delete: if isVerified() && request.auth.uid == userId;
      
      match /friends/{friendId} {
        allow list, get: if isSignedIn() && request.auth.uid == userId;
        allow create: if isVerified() && request.auth.uid == userId && isValidFriend(incoming());
        allow update: if isVerified() && request.auth.uid == userId && isValidFriend(incoming());
        allow delete: if isVerified() && request.auth.uid == userId;
      }
    }

    match /groups/{groupId} {
      function isMember(data) {
        return isSignedIn() && (
          (request.auth.uid in data.get('memberUids', [])) ||
          data.get('leaderUid', '') == request.auth.uid
        );
      }

      allow list: if isSignedIn() && (
        (request.auth.uid in resource.data.memberUids) ||
        (resource.data.leaderUid == request.auth.uid)
      );
      allow get: if isSignedIn();
      
      allow create: if isVerified() && isValidGroup(incoming()) && (request.auth.uid in incoming().memberUids);
      
      allow update: if isVerified() && isValidGroup(incoming())
        && (
          // Leader can update anything
          (resource.data.get('leaderUid', '') == request.auth.uid) ||
          // Member updates (metadata or members)
          (isMember(resource.data) && 
            incoming().diff(existing()).affectedKeys().hasOnly(['name', 'emoji', 'dueDate', 'memberDetails', 'members', 'memberUids', 'updatedAt'])) ||
          // Join action
          (!isMember(resource.data) && (request.auth.uid in incoming().get('memberUids', [])) && 
            incoming().diff(existing()).affectedKeys().hasOnly(['members', 'memberUids', 'memberDetails', 'updatedAt']))
        );
      
      allow delete: if isVerified() && resource.data.get('leaderUid', '') == request.auth.uid;

      match /expenses/{expenseId} {
        allow list, get: if isMember(get(/databases/$(database)/documents/groups/$(groupId)).data);
        allow create: if isVerified() && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data) && isValidExpense(incoming());
        allow update: if isVerified() && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data) && isValidExpense(incoming()) && incoming().createdBy == existing().createdBy;
        allow delete: if isVerified() && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data) && (existing().createdBy == request.auth.uid || get(/databases/$(database)/documents/groups/$(groupId)).data.leaderUid == request.auth.uid);
      }

      match /payments/{paymentId} {
        allow list, get: if isMember(get(/databases/$(database)/documents/groups/$(groupId)).data);
        allow create: if isVerified() && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data) && isValidPayment(incoming());
        allow update: if isVerified() && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data) && isValidPayment(incoming()) && incoming().createdBy == existing().createdBy;
        allow delete: if isVerified() && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data) && (existing().createdBy == request.auth.uid || get(/databases/$(database)/documents/groups/$(groupId)).data.leaderUid == request.auth.uid);
      }

      match /feed/{feedId} {
        allow list, get: if isMember(get(/databases/$(database)/documents/groups/$(groupId)).data);
        allow create: if isVerified() && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data) && isValidFeedItem(incoming());
        allow delete: if isVerified() && get(/databases/$(database)/documents/groups/$(groupId)).data.leaderUid == request.auth.uid;
      }
    }
  }
}
